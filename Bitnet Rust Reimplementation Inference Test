    #[inline]
    pub fn tokenizer(&self) -> &Tokenizer {
        &self.tokenizer
    }

    /// Returns the current number of positions in the KV cache.
    #[inline]
    pub fn context_length(&self) -> usize {
        self.kv_cache.filled_positions
    }
