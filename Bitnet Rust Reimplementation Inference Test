    ///
    /// # Errors
    ///
    /// Returns an error only for unexpected internal tokeniser failures.
    pub fn decode_single(&self, token: u32) -> anyhow::Result<Option<Vec<u8>>> {
        if token >= 128_000 {
            return Ok(None);
        }
        match self.inner.decode(&[token], false) {
            Ok(text) => Ok(Some(text.into_bytes())),
            Err(_) => Ok(None),
