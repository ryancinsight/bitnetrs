    fn generate_from_tokens(
        &mut self,
        tokens: Vec<u32>,
        sampling: &SamplingConfig,
    ) -> anyhow::Result<String> {
        sampling.validate().context("Invalid sampling config")?;

        if tokens.is_empty() {
            return Ok(String::new());
        }

        // Reset KV cache for a clean generation.
        self.kv_cache.clear();

        // Prefill: process all prompt tokens.
        let mut logits = self
            .model
            .forward(&tokens, 0, &mut self.kv_cache)
            .context("Prefill forward pass failed")?;

        debug!(prefill_tokens = tokens.len(), "Prefill complete");

        // Autoregressive decode loop.
        let mut generated: Vec<u32> = Vec::with_capacity(sampling.max_new_tokens);
        let eos_eot = self.tokenizer.eos_token_id(); // 128009 <|eot_id|>
        let eos_eot_text = 128_001_u32; // <|end_of_text|>

        for step in 0..sampling.max_new_tokens {
            // Sample next token.
            let all_tokens: Vec<u32> = tokens.iter().chain(generated.iter()).cloned().collect();
            let next_token = sample_next_token(&mut logits, sampling, &all_tokens);

            if next_token == eos_eot || next_token == eos_eot_text {
                debug!(
                    step,
                    token = next_token,
                    "EOS/EOT token produced; stopping generation"
                );
                break;
            }

            generated.push(next_token);
            debug!(step, token = next_token, "Generated token");

            // Decode step: forward pass for the single new token.
            let cur_pos = self.kv_cache.filled_positions;
            logits = self
                .model
                .forward(&[next_token], cur_pos, &mut self.kv_cache)
                .with_context(|| format!("Decode forward pass failed at step {step}"))?;
        }

        debug!(n_generated = generated.len(), "Generation complete");

        // Decode generated tokens to text.
        self.tokenizer
            .decode(&generated)
            .context("Failed to decode generated tokens")
    }

    /// Generate a response for a chat conversation.
    ///
    /// Applies the LLaMA 3 Instruct chat template to `messages`, then generates
    /// a response autoregressively.
    ///
    /// # Arguments
    ///
    /// - `messages`: Ordered list of conversation messages.
    /// - `sampling`: Sampling hyperparameters.
    ///
    /// # Returns
    ///
    /// The assistant's response as a UTF-8 string.
    ///
