                self.backend
                    .ternary_gemv_with_activation_quant(
                        &layer.down_proj.data,
                        layer.down_proj.scale,
                        &inner_normed,
                        &mut ffn_out,
                        hidden_size,
                        ffn_dim,
                    )
                    .with_context(|| format!("layer {layer_idx}, tok {tok_offset}: down_proj"))?;

                // ── Residual connection (FFN) ──────────────────────────────────
                for i in 0..hidden_size {
                    h[i] += ffn_out[i];
