    }

    fn squared_relu(&self, x: &mut [f32]) -> Result<()> {
        (**self).squared_relu(x)
    }

    fn softmax(&self, x: &mut [f32]) -> Result<()> {
        (**self).softmax(x)
    }

    fn elementwise_mul(&self, a: &[f32], b: &[f32], out: &mut [f32]) -> Result<()> {
        (**self).elementwise_mul(a, b, out)
    }

    fn device_name(&self) -> &str {
        (**self).device_name()
    }
}

